        prompt: str, 
        max_task_size: str = "bite-sized"
    ) -> list[Task]:
        """
        Decompose a complex prompt into manageable tasks.
        
        Args:
            prompt: The original complex request
            max_task_size: Target task granularity
            
        Returns:
            List of Task objects in execution order
        """
        self._task_counter = 0
        
        # First, identify the major phases
        phases = self._identify_phases(prompt)
        
        tasks = []
        for phase in phases:
            phase_tasks = self._decompose_phase(phase, tasks)
            tasks.extend(phase_tasks)
        
        # Add dependency links
        tasks = self._link_dependencies(tasks)
        
        # Validate and optimize
        tasks = self._optimize_task_graph(tasks)
        
        return tasks
    
    def _identify_phases(self, prompt: str) -> list[dict]:
        """Identify major phases or components of the work."""
        phases = []
        
        # Detection patterns for different work types
        work_patterns = {
            'setup': r'(setup|install|initialize|configure|prepare)',
            'core': r'(implement|build|create|develop|design)',
            'integrate': r'(integrate|connect|hook|wire|link)',
            'secure': r'(secure|authenticate|authorize|encrypt|protect)',
            'optimize': r'(optimize|improve|enhance|refine|tune)',
            'test': r'(test|verify|validate|check|ensure)',
            'deploy': r'(deploy|release|publish|launch|ship)',
            'document': r'(document|document|describe|explain)',
        }
        
        prompt_lower = prompt.lower()
        
        # Check for explicit sequential markers
        sequential_markers = [
            'first', 'then', 'next', 'after', 'before', 'finally',
            'step 1', 'step 2', 'phase 1', 'phase 2'
        ]
        
        has_explicit_sequence = any(
            marker in prompt_lower for marker in sequential_markers
        )
        
        if has_explicit_sequence:
            # Use explicit ordering
            phases = self._extract_explicit_phases(prompt)
        else:
            # Infer phases from content
            phases = self._infer_phases(prompt, work_patterns)
        
        return phases if phases else [{'type': 'main', 'description': prompt}]
    
    def _extract_explicit_phases(self, prompt: str) -> list[dict]:
        """Extract phases from explicitly ordered text."""
        phases = []
        
        # Split by common transition words
        segments = re.split(
            r'\s+(?:first|then|next|after that|finally|step \d+|phase \d+)\s+:?\s*',
            prompt,
            flags=re.IGNORECASE
        )
        
        for i, segment in enumerate(segments):
            if segment.strip() and len(segment.strip()) > 10:
                phases.append({
                    'type': f'phase_{i}',
                    'description': segment.strip(),
                    'order': i
                })
        
        return phases
    
    def _infer_phases(self, prompt: str, patterns: dict) -> list[dict]:
        """Infer phases from content analysis."""
        phases = []
        prompt_lower = prompt.lower()
        
        for phase_type, pattern in patterns.items():
            if re.search(pattern, prompt_lower):
                # Find the relevant portion
                match = re.search(pattern, prompt_lower)
                if match:
                    # Extract context around the match
                    start = max(0, match.start() - 50)
                    end = min(len(prompt), match.end() + 100)
                    context = prompt[start:end]
                    
                    phases.append({
                        'type': phase_type,
                        'description': context.strip(),
                        'order': len(phases)
                    })
        
        return phases
    
